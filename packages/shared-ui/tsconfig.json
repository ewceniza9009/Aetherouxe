{
  "extends": "@elite-realty/config-tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "declarationDir": "dist",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}