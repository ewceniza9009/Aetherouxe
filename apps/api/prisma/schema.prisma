model Notification {
  id        String           @id @default(cuid())
  role      NotificationRole
  userId    String?
  tenantId  String?
  ownerId   String?
  type      NotificationType
  title     String
  message   String
  link      String?
  refId     String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// GENERAL LEDGER & ACCOUNTS PAYABLE (PHASE 8)
// ─────────────────────────────────────────────

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}

model ChartOfAccount {
  id          String      @id @default(uuid())
  tenantId    String
  accountCode String
  name        String
  type        AccountType
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  journalLines JournalLine[]

  @@unique([tenantId, accountCode])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id        String   @id @default(uuid())
  tenantId  String
  reference String?
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  lines  JournalLine[]

  @@map("journal_entries")
}

model JournalLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String
  debitAmount    Decimal @default(0) @db.Decimal(14, 2)
  creditAmount   Decimal @default(0) @db.Decimal(14, 2)
  description    String?

  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

model FinancialMapping {
  id              String @id @default(uuid())
  tenantId        String
  transactionType String // e.g. WORK_ORDER_COMPLETED
  debitAccountId  String
  creditAccountId String

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, transactionType])
  @@map("financial_mappings")
}

enum ApInvoiceStatus {
  pending_approval
  approved
  paid
  cancelled
}

model ApInvoice {
  id            String          @id @default(uuid())
  tenantId      String
  sourceType    String // e.g. WORK_ORDER, COMMISSION, MISC_EXPENSE
  sourceId      String?
  vendorId      String?
  invoiceNumber String?
  amount        Decimal         @db.Decimal(14, 2)
  dueDate       DateTime?
  status        ApInvoiceStatus @default(pending_approval)
  notes         String?
  createdAt     DateTime        @default(now())

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  vendor        Contractor?      @relation(fields: [vendorId], references: [id])
  disbursements ApDisbursement[]

  // List performance: filter/sort fields used by the ap-invoices list endpoint.
  @@index([tenantId, status])
  @@index([tenantId, sourceType])
  @@index([tenantId, vendorId])
  @@index([tenantId, dueDate])
  @@index([tenantId, createdAt])

  @@map("ap_invoices")
}

model ApDisbursement {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Decimal  @db.Decimal(14, 2)
  paymentDate   DateTime @default(now())
  paymentMethod String?
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())

  invoice ApInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("ap_disbursements")
}
