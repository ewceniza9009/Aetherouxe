// ─────────────────────────────────────────────
// SALES SCHEMES (Master Data — All Transaction Types)
// ─────────────────────────────────────────────

enum SchemeType {
  standard_rental // Monthly lease with deposit + penalty terms
  spot_cash // Full upfront payment with optional discount
  installment // DP + Equity + Balance phases (in-house financing)
  mortgage_assisted // DP in-house, balance via bank mortgage
  rent_to_own // Rent with equity accumulation toward purchase
}

model Scheme {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String?
  schemeType SchemeType
  remarks    String?
  projectId  String?
  isLocked   Boolean    @default(false)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // ── Standard Rental ──
  securityDepositPercent Decimal? @db.Decimal(8, 4) // % of monthly rent
  penaltyPercent         Decimal? @db.Decimal(8, 4) // late fee % per day
  graceDays              Int? // days before penalty

  // ── Spot Cash ──
  discountPercent Decimal? @db.Decimal(8, 4) // cash discount %

  // ── Installment (DP / Equity / Balance) ──
  dpNumberOfPayments   Int?
  dpNumberOfDaysFromDp Int?
  dpAmount             Decimal? @db.Decimal(12, 2)
  dpRemarks            String?

  eqNumberOfPayments       Int?
  eqNumberOfDaysFromDp     Int?
  eqAmount                 Decimal? @db.Decimal(12, 2)
  eqPaymentPercentage      Decimal? @db.Decimal(8, 4) // % of selling price allocated to equity
  eqDownpaymentPercentage  Decimal? @db.Decimal(8, 4) // equity share used for DP computation
  eqMonthlyAmortPercentage Decimal? @db.Decimal(8, 4) // equity share spread monthly
  eqDiscountPercentage     Decimal? @db.Decimal(8, 4) // discount on equity portion
  eqPaymentOrderNumber     Int?
  eqRemarks                String?

  blNumberOfPayments   Int?
  blNumberOfDaysFromDp Int?
  blAmount             Decimal? @db.Decimal(12, 2)
  blPaymentPercentage  Decimal? @db.Decimal(8, 4) // % of selling price allocated to balance
  blMiscPercentage     Decimal? @db.Decimal(8, 4) // transfer fees / misc
  blIsChangeOrder      Boolean  @default(false)
  blIncludeDpAmort     Boolean  @default(false) // spread misc across DP+EQ months
  blRemarks            String?

  // ── Mortgage Assisted ──
  mortgageDownPaymentPercent Decimal? @db.Decimal(8, 4) // buyer's downpayment to bank
  interestRatePercent        Decimal? @db.Decimal(8, 4) // annual interest rate
  loanTermMonths             Int? // bank loan term

  // ── Rent-to-Own ──
  optionFeePercent          Decimal? @db.Decimal(8, 4) // option fee as % of contract value
  equityAccumulationPercent Decimal? @db.Decimal(8, 4) // % of rent that accumulates as equity
  targetPurchaseYears       Int? // years until purchase option matures

  // ── Commissions (all sale types) ──
  agentCommissionPercentage   Decimal? @db.Decimal(8, 4)
  companyCommissionPercentage Decimal? @db.Decimal(8, 4)

  leases LeaseAgreement[]

  @@map("schemes")
}

// ─────────────────────────────────────────────
// TITLE TRANSFER (Owner → Buyer handover)
// ─────────────────────────────────────────────

enum TitleTransferStatus {
  pending // Requested / initiated, awaiting requirements
  in_progress // Documents being processed (BIR, Registry of Deeds)
  completed // Title transferred; buyer is new owner of record
  cancelled // Transfer aborted
}

enum TitleTransferBasis {
  spot_cash // Fully paid in cash
  installment_paid // In-house installment fully paid
  rto_exercised // Rent-to-own option exercised / equity complete
  mortgage_settled // Bank/Pag-IBIG loan released to developer
  manual // Administrative / other
}

model TitleTransfer {
  id                  String              @id @default(uuid())
  tenantId            String
  propertyId          String
  unitId              String?
  leaseAgreementId    String?
  rtoContractId       String?
  buyerUserId         String // becomes the new owner of record
  previousOwnerUserId String? // prior owner (developer/landlord) if known
  basis               TitleTransferBasis
  status              TitleTransferStatus @default(pending)
  titleNumber         String? // TCT / CCT number issued
  contractValue       Decimal?            @db.Decimal(14, 2)
  amountSettled       Decimal?            @db.Decimal(14, 2)
  transferFeeAmount   Decimal?            @db.Decimal(12, 2)
  requestedDate       DateTime            @default(now())
  completedDate       DateTime?
  titleDocumentUrl    String?
  notes               String?
  processedByUserId   String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  unit          Unit?           @relation(fields: [unitId], references: [id])
  lease         LeaseAgreement? @relation(fields: [leaseAgreementId], references: [id])
  buyer         User            @relation("TitleTransferBuyer", fields: [buyerUserId], references: [id])
  previousOwner User?           @relation("TitleTransferPreviousOwner", fields: [previousOwnerUserId], references: [id])
  processedBy   User?           @relation("TitleTransferProcessedBy", fields: [processedByUserId], references: [id])

  @@index([propertyId])
  @@index([buyerUserId])
  @@index([status])
  // Multi-tenant list scoping for the titles list endpoint.
  @@index([tenantId, propertyId])
  @@index([tenantId, buyerUserId])
  @@index([tenantId, status])
  @@index([tenantId, requestedDate])
  @@map("title_transfers")
}

